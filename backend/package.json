{
  "name": "backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "start": "node dist/index.js",
    "test": "bun test",
    "test:client": "RUN_TESTS=true bun run src/index.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.2.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^2.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.3",
    "hono": "^4.7.11",
    "openai": "^4.42.0",
    "postgres": "^3.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.21.0",
    "typescript": "^5.4.5"
  }
}
